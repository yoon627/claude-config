{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main *)",
      "Bash(git push origin master)",
      "Bash(git push origin master *)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:master)",
      "Bash(git push origin HEAD:master *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \"$env:USERPROFILE\\.claude\\scripts\\notify-hook.ps1\" -Event Stop -Sound Asterisk",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \"$env:USERPROFILE\\.claude\\scripts\\notify-hook.ps1\" -Event Notification -Sound Exclamation",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell -NoProfile -Command 'node \"$env:USERPROFILE\\.claude\\statusline.js\"'",
    "refreshInterval": 2
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "powershell -NoProfile -Command 'node \"$env:USERPROFILE\\.claude\\subagent-statusline.js\"'"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true
}
