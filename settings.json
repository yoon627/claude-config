{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh"
  },
  "permissions": {
    "allow": [
      "mcp__codegraph__codegraph_explore",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_status"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main *)",
      "Bash(git push origin master)",
      "Bash(git push origin master *)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:master)",
      "Bash(git push origin HEAD:master *)",
      "PowerShell(git push origin main)",
      "PowerShell(git push origin main *)",
      "PowerShell(git push origin main:*)",
      "PowerShell(git push origin HEAD:main)",
      "PowerShell(git push origin HEAD:main *)",
      "PowerShell(git push origin master)",
      "PowerShell(git push origin master *)",
      "PowerShell(git push origin master:*)",
      "PowerShell(git push origin HEAD:master)",
      "PowerShell(git push origin HEAD:master *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "PowerShell(git push)",
      "PowerShell(git push *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/guard-worktree-edit.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uname -s | grep -qi darwin && /Users/jongyoonlee/.claude/hooks/rtk-rewrite.sh || exit 0"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/dlc-task-router.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/dlc-evidence-ledger.js",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C ~/.claude rev-parse --abbrev-ref HEAD 2>/dev/null | grep -qx main && git -C ~/.claude diff --quiet 2>/dev/null && git -C ~/.claude diff --cached --quiet 2>/dev/null && before=$(git -C ~/.claude rev-parse HEAD 2>/dev/null) && git -C ~/.claude pull --ff-only --quiet origin main >/dev/null 2>&1 && after=$(git -C ~/.claude rev-parse HEAD 2>/dev/null) && [ \"$before\" != \"$after\" ] && echo \"~/.claude updated from origin/main ($before -> $after); review pulled changes before relying on scripts/hooks this session.\" || true",
            "timeout": 30,
            "statusMessage": "Checking ~/.claude for updates",
            "async": true
          },
          {
            "type": "command",
            "command": "node ~/.claude/scripts/session-brief.js",
            "timeout": 10,
            "statusMessage": "세션 브리프"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/dlc-early-stop.js",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/notify-hook.js Stop",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/notify-hook.js Notification",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js",
    "refreshInterval": 2
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "node ~/.claude/subagent-statusline.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "preferredNotifChannel": "notifications_disabled"
}
