{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main *)",
      "Bash(git push origin master)",
      "Bash(git push origin master *)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:master)",
      "Bash(git push origin HEAD:master *)",
      "PowerShell(git push origin main)",
      "PowerShell(git push origin main *)",
      "PowerShell(git push origin main:*)",
      "PowerShell(git push origin HEAD:main)",
      "PowerShell(git push origin HEAD:main *)",
      "PowerShell(git push origin master)",
      "PowerShell(git push origin master *)",
      "PowerShell(git push origin master:*)",
      "PowerShell(git push origin HEAD:master)",
      "PowerShell(git push origin HEAD:master *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "PowerShell(git push)",
      "PowerShell(git push *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C ~/.claude rev-parse --abbrev-ref HEAD 2>/dev/null | grep -qx main && git -C ~/.claude diff --quiet 2>/dev/null && git -C ~/.claude diff --cached --quiet 2>/dev/null && before=$(git -C ~/.claude rev-parse HEAD 2>/dev/null) && git -C ~/.claude pull --ff-only --quiet origin main >/dev/null 2>&1 && after=$(git -C ~/.claude rev-parse HEAD 2>/dev/null) && [ \"$before\" != \"$after\" ] && echo \"~/.claude updated from origin/main ($before -> $after); review pulled changes before relying on scripts/hooks this session.\" || true",
            "timeout": 30,
            "statusMessage": "Checking ~/.claude for updates",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/notify-hook.js Stop",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/notify-hook.js Notification",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js",
    "refreshInterval": 2
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "node ~/.claude/subagent-statusline.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "preferredNotifChannel": "notifications_disabled"
}
