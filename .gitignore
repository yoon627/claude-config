# Whitelist approach: ignore everything at root, then allow specific items.
# Once a directory is unignored, its contents are auto-included.
/*

# Allowed top-level items
!/.editorconfig
!/.github/
!/.gitignore
!/CLAUDE.md
!/LICENSE
!/README.md
!/agents/
!/codex-quota-refresh.js
!/commands/
!/scripts/
!/settings.json
!/settings.macos.json
!/skills/
!/statusline.js
!/subagent-statusline.js

# Belt-and-suspenders: never push these even if the whitelist is changed by mistake.
.credentials.json
settings.local.json
history.jsonl
*.bak
*.bak.*
tmp_*
