# Whitelist approach: ignore everything at root, then allow specific items.
# Once a directory is unignored, its contents are auto-included.
/*

# Allowed top-level items
!/.editorconfig
!/.gitattributes
!/.github/
!/.gitignore
!/CLAUDE.md
!/LICENSE
!/README.md
!/agents/
!/codex-quota-refresh.js
!/commands/
!/docs/
!/scripts/
!/settings.json
!/skills/
!/statusline.js
!/subagent-statusline.js
!/wiki/

# LLM Wiki: pages/index/log are tracked; raw sources are not (copyright/size).
wiki/raw/

# Belt-and-suspenders: never push these even if the whitelist is changed by mistake.
.credentials.json
settings.local.json
history.jsonl
*.bak
*.bak.*
tmp_*

# Python bytecode cache inside whitelisted dirs (e.g. scripts/)
__pycache__/
*.pyc
