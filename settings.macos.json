{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh"
  },
  "permissions": {
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main *)",
      "Bash(git push origin master)",
      "Bash(git push origin master *)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:master)",
      "Bash(git push origin HEAD:master *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-hook.sh Stop Glass",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-hook.sh Notification Ping",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/statusline.js",
    "refreshInterval": 2
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "node $HOME/.claude/subagent-statusline.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true
}
